---
import '../styles/footer.css'
import FooterLogo from '../assets/logoblanco.png'
import { es } from '../i18n/es.js'
import { en } from '../i18n/en.js'

interface Props {
  lang?: string;
  currentYear?: number;
}

const { lang = 'es', currentYear = new Date().getFullYear() } = Astro.props
const t = (lang === 'en' ? en : es).footer

const socialLinks = [
  {
    label: "LinkedIn",
    href: "#linkedin",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
      <rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
    </svg>`,
  },
  {
    label: "Twitter / X",
    href: "#twitter",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>`,
  },
  {
    label: "Instagram",
    href: "#instagram",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
    </svg>`,
  },
  {
    label: "YouTube",
    href: "#youtube",
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
      <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
      <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
    </svg>`,
  },
]
---

<footer class="ikari-footer">

  <div class="footer-body">

    <div class="footer-brand-col">
      <a href="#" class="footer-logo" aria-label={t.ariaLogo}>
        <img src={FooterLogo.src} />
      </a>
      <p class="footer-tagline">
        CRM &amp; {lang === 'en' ? 'Internal Management' : 'Gestión Interna'} for {lang === 'en' ? 'clinics, agencies and businesses that need a' : 'clínicas, agencias y empresas que necesitan un'}
        {' '}<strong>{t.taglineStrong}</strong>{' '}
        {lang === 'en' ? 'to scale without losing control.' : 'para escalar sin perder el control.'}
      </p>

      <div class="footer-badges">
        {t.badges.map(b => <span class="footer-badge">{b}</span>)}
      </div>

      <div class="footer-socials">
        {socialLinks.map((s) => (
          <a href={s.href} class="social-btn" aria-label={s.label} set:html={s.icon} />
        ))}
      </div>
    </div>

    <nav class="footer-nav-grid" aria-label={t.ariaFooterNav}>
      {t.columnas.map((col) => (
        <div class="footer-nav-col">
          <p class="footer-nav-heading">{col.heading}</p>
          <ul class="footer-nav-list">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="footer-nav-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copy">
        © {currentYear} <strong>Ikari CRM</strong>. {t.copy}
      </p>
    </div>
  </div>

</footer>

<script>
  import '../scripts/footer'
</script>