---
import '../styles/target.css'
---

<section class="sec-section" id="sectores">
 
  <!-- Header centrado -->
  <div class="sec-header">
    <span class="sec-eyebrow">Mercado Target</span>
    <h2 class="sec-title">Un sistema adaptado<br/>a <em>tu industria.</em></h2>
    <p class="sec-lead">Selecciona tu sector y descubre cómo Ikari se reconfigura para ti.</p>
  </div>
 
  <!-- Grid principal -->
  <div class="sec-layout">
 
    <!-- ── Izquierda: grid 2×2 de sectores ── -->
    <div class="sec-grid" role="tablist" aria-label="Selecciona tu sector">
 
      <!-- Clínicas -->
      <button class="sec-card active" data-sector="salud" role="tab" aria-selected="true">
        <div class="sec-card-icon salud">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.5 12.5l8-8a4.94 4.94 0 0 1 7 7l-8 8a4.94 4.94 0 0 1-7-7"/>
            <path d="M9 12h4"/><path d="M11 10v4"/>
          </svg>
        </div>
        <p class="sec-card-title">Clínicas y Salud</p>
        <p class="sec-card-sub">Gestión médica inteligente</p>
        <span class="sec-card-indicator" aria-hidden="true"></span>
      </button>
 
      <!-- Agencias -->
      <button class="sec-card" data-sector="agencias" role="tab" aria-selected="false">
        <div class="sec-card-icon agencias">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="12.01"/>
            <path d="M3 13a20 20 0 0 0 18 0"/>
          </svg>
        </div>
        <p class="sec-card-title">Agencias</p>
        <p class="sec-card-sub">Pipeline B2B acelerado</p>
        <span class="sec-card-indicator" aria-hidden="true"></span>
      </button>
 
      <!-- Bienes Raíces -->
      <button class="sec-card" data-sector="real" role="tab" aria-selected="false">
        <div class="sec-card-icon real">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 21l18 0"/>
            <path d="M5 21v-16a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/>
            <path d="M9 8l1 0"/><path d="M9 12l1 0"/><path d="M9 16l1 0"/>
            <path d="M14 8l1 0"/><path d="M14 12l1 0"/><path d="M14 16l1 0"/>
          </svg>
        </div>
        <p class="sec-card-title">Bienes Raíces</p>
        <p class="sec-card-sub">Catálogo + CRM integrado</p>
        <span class="sec-card-indicator" aria-hidden="true"></span>
      </button>
 
      <!-- Corporativo -->
      <button class="sec-card" data-sector="corp" role="tab" aria-selected="false">
        <div class="sec-card-icon corp">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8"/><path d="M12 17v4"/>
            <path d="M7 8h2"/><path d="M7 12h2"/>
            <path d="M15 8h2"/><path d="M15 12h2"/>
            <path d="M11 8h2"/><path d="M11 12h2"/>
          </svg>
        </div>
        <p class="sec-card-title">Multi-sede</p>
        <p class="sec-card-sub">Control corporativo total</p>
        <span class="sec-card-indicator" aria-hidden="true"></span>
      </button>
 
    </div>
 
    <!-- ── Derecha: panel dinámico ── -->
    <div class="sec-panel" id="secPanel" aria-live="polite">
 
      <!-- Los paneles se renderizan por JS -->
      <div class="sec-panel-inner" id="secPanelInner"></div>
 
    </div>
 
  </div>
</section>

<script>
  import '../scripts/taget'
</script>