---
import '../styles/roadmap.css'
---

<section class="ct-section" id="contacto">

  <div class="ct-header">
 <span class="arq-eyebrow">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
      stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2"/>
      <path d="M8 21h8"/><path d="M12 17v4"/>
    </svg>
  Proceso Simple
  </span>
    <h2 class="ct-title">De la primera consulta<br/><em>al sistema activo.</em></h2>
       <p class="ct-process-lead">
        Nuestro proceso está diseñado para que tengas Ikari operando en menos de una semana,
        con acompañamiento en cada paso.
      </p>
 
  </div>

  <div class="ct-layout">
 
    <!-- ══ IZQUIERDA -->
    <div class="ct-chat-wrap">
      <div class="ct-chat">
 
        <!-- Header del chat -->
        <div class="ct-chat-header">
          <div class="ct-chat-avatar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div class="ct-chat-info">
            <p class="ct-chat-name">Ikari — Equipo Comercial</p>
            <p class="ct-chat-status">
              <span class="ct-online-dot"></span>
              En línea ahora
            </p>
          </div>
          <div class="ct-chat-badge">CRM Demo</div>
        </div>
 
        <!-- Mensajes -->
        <div class="ct-messages" id="ctMessages">
          <!-- Se renderizan por JS -->
        </div>
 
        <!-- Input (decorativo) -->
        <div class="ct-chat-input">
          <input type="text" placeholder="Escribe un mensaje..." disabled />
          <button class="ct-send-btn" aria-label="Enviar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </div>
 
      </div>
    </div>
 
    <!-- ══ DERECHA -->
    <div class="ct-process">
 
   
      <!-- Pasos -->
      <ol class="ct-steps">
 
        <li class="ct-step">
          <div class="ct-step-icon" style="--step-c:#53c6d6;--step-bg:#eef7f9">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div class="ct-step-body">
            <p class="ct-step-title">Nos contactas</p>
            <p class="ct-step-desc">Por WhatsApp, la web o redes. Sin formularios largos ni esperas — respondemos en menos de 2 horas.</p>
          </div>
          <span class="ct-step-num">01</span>
        </li>
 
        <li class="ct-step">
          <div class="ct-step-icon" style="--step-c:#2b61ae;--step-bg:#e8f0fb">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <div class="ct-step-body">
            <p class="ct-step-title">Demo personalizada (30 min)</p>
            <p class="ct-step-desc">Te mostramos Ikari con casos reales de tu industria. Sin plantillas genéricas — solo lo que importa para tu negocio.</p>
          </div>
          <span class="ct-step-num">02</span>
        </li>
 
        <li class="ct-step">
          <div class="ct-step-icon" style="--step-c:#f26b4f;--step-bg:#fff3f0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div class="ct-step-body">
            <p class="ct-step-title">Propuesta sin sorpresas</p>
            <p class="ct-step-desc">Plan exacto para tu operación: sedes, usuarios, módulos y precio final. Sin letra pequeña ni costos ocultos.</p>
          </div>
          <span class="ct-step-num">03</span>
        </li>
 
        <li class="ct-step">
          <div class="ct-step-icon" style="--step-c:#ccdc60;--step-bg:#f5fadf">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <div class="ct-step-body">
            <p class="ct-step-title">Setup y capacitación</p>
            <p class="ct-step-desc">Configuramos Ikari para ti, migramos tus datos y capacitamos a tu equipo. Tú solo te presentas el día 1.</p>
          </div>
          <span class="ct-step-num">04</span>
        </li>
 
        <li class="ct-step">
          <div class="ct-step-icon" style="--step-c:#0e1c38;--step-bg:#e8eef4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
          </div>
          <div class="ct-step-body">
            <p class="ct-step-title">Go Live — operando desde el día 1</p>
            <p class="ct-step-desc">Tu sistema activo con leads, agenda y finanzas funcionando. Con soporte en vivo durante el lanzamiento.</p>
          </div>
          <span class="ct-step-num">05</span>
        </li>
 
      </ol>
 
      <!-- CTA -->
      <div class="ct-ctas">
        <a href="#demo" class="ct-btn ct-btn--primary">
          Agendar mi demo gratuita
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="https://wa.me/1234567890" class="ct-btn ct-btn--wa" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escribir por WhatsApp
        </a>
      </div>
 
    </div>
 
  </div>
</section>
<script>
    import '../scripts/roadmap'
</script>