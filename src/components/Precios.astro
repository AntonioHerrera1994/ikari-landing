---
import '../styles/precios.css'
import { es } from '../i18n/es.js'
import { en } from '../i18n/en.js'

const { lang = 'es' } = Astro.props
const t = (lang === 'en' ? en : es).precios

const planes = ['ancla', 'comando', 'corporativo']
---

<section class="precios-section" id="precios" data-lang={lang}>

  <div class="precios-header">
    <span class="arq-eyebrow">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <path d="M8 21h8"/><path d="M12 17v4"/>
      </svg>
      {t.eyebrow}
    </span>
    <h2 class="precios-title" set:html={t.titulo} />
    <p class="precios-subtitle">{t.subtitulo}</p>

    <div class="billing-toggle">
      <span class="billing-label active" id="label-mensual">{t.toggleMensual}</span>
      <button class="toggle-track" id="billing-toggle" role="switch" aria-checked="false" aria-label={t.ariaToggle}>
        <span class="toggle-thumb"></span>
      </button>
      <span class="billing-label" id="label-anual">
        {t.toggleAnual}
        <span class="badge-ahorro">{t.badgeAhorro}</span>
      </span>
    </div>
  </div>

  <div class="planes-grid">

    <!-- PLAN ANCLA -->
    <div class="plan-card" id="plan-ancla">
      <div class="plan-head">
        <div class="plan-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v6M12 22v-4M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-4M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">{t.planes.ancla.nombre}</p>
          <p class="plan-tagline">{t.planes.ancla.tagline}</p>
        </div>
      </div>
      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">1,699</span>
          <span class="price-period">{t.periodoMes}</span>
        </div>
        <p class="price-note" id="note-ancla">{t.notaMensual}</p>
      </div>
      <a href="mailto:info@ikaricrm.com" target="_blank" rel="noopener noreferrer" class="plan-cta plan-cta--outline">{t.planes.ancla.cta}</a>
      <div class="plan-features">
        <p class="features-label">{t.planes.ancla.featuresLabel}</p>
        <ul class="features-list">
          {t.planes.ancla.features.map(f => (
            <li class={`feat feat--${f.on ? 'on' : 'off'}`}>
              <span class="feat-icon">{f.on ? '✓' : '—'}</span> {f.text}
            </li>
          ))}
        </ul>
      </div>
      <p class="plan-support">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        {t.planes.ancla.soporte}
      </p>
    </div>

    <!-- PLAN COMANDO -->
    <div class="plan-card plan-card--featured" id="plan-comando">
      <div class="plan-badge">{t.masPopular}</div>
      <div class="plan-head">
        <div class="plan-icon plan-icon--featured">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">{t.planes.comando.nombre}</p>
          <p class="plan-tagline">{t.planes.comando.tagline}</p>
        </div>
      </div>
      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">2,199</span>
          <span class="price-period">{t.periodoMes}</span>
        </div>
        <p class="price-note" id="note-comando">{t.notaMensual}</p>
      </div>
      <a href="mailto:info@ikaricrm.com" target="_blank" rel="noopener noreferrer" class="plan-cta plan-cta--primary">{t.planes.comando.cta}</a>
      <div class="plan-features">
        <p class="features-label">{t.planes.comando.featuresLabel}</p>
        <ul class="features-list">
          {t.planes.comando.features.map(f => (
            <li class={`feat feat--${f.on ? 'on' : 'off'}`}>
              <span class="feat-icon">{f.on ? '✓' : '—'}</span> {f.text}
            </li>
          ))}
        </ul>
      </div>
      <p class="plan-support plan-support--featured">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {t.planes.comando.soporte}
      </p>
    </div>

    <!-- PLAN CORPORATIVO -->
    <div class="plan-card" id="plan-corporativo">
      <div class="plan-head">
        <div class="plan-icon plan-icon--corp">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">{t.planes.corporativo.nombre}</p>
          <p class="plan-tagline">{t.planes.corporativo.tagline}</p>
        </div>
      </div>
      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">2,699</span>
          <span class="price-period">{t.periodoMes}</span>
        </div>
        <p class="price-note" id="note-corporativo">{t.notaMensual}</p>
      </div>
      <a href="mailto:info@ikaricrm.com" class="plan-cta plan-cta--outline">{t.planes.corporativo.cta}</a>
      <div class="plan-features">
        <p class="features-label">{t.planes.corporativo.featuresLabel}</p>
        <ul class="features-list">
          {t.planes.corporativo.features.map(f => (
            <li class={`feat feat--${f.on ? 'on' : 'off'}${f.highlight ? ' feat--highlight' : ''}`}>
              <span class="feat-icon">{f.on ? '✓' : '—'}</span>
              {f.badge
                ? <span>{f.text} <span class="feat-new">{f.badge}</span></span>
                : f.text
              }
            </li>
          ))}
        </ul>
      </div>
      <p class="plan-support">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8a16 16 0 0 0 6 6l.27-.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>
        {t.planes.corporativo.soporte}
      </p>
    </div>

  </div>

</section>

<link rel="stylesheet" href="/styles/PreciosIkari.css" />
<script src="/scripts/PreciosIkari.js" defer></script>
<script>
  import '../scripts/precios.js'
</script>