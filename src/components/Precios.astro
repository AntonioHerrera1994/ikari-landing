---
import '../styles/precios.css'
---


<section class="precios-section" id="precios">

  <!-- Header -->
  <div class="precios-header">
    <span class="precios-eyebrow">Planes & Precios</span>
    <h2 class="precios-title">El ancla que tu negocio necesita,<br/>al precio que merece.</h2>
    <p class="precios-subtitle">
      Sin permanencia. Sin costes ocultos. Cancela cuando quieras.
    </p>

    <!-- Toggle mensual / anual -->
    <div class="billing-toggle">
      <span class="billing-label" id="label-mensual">Mensual</span>
      <button class="toggle-track" id="billing-toggle" role="switch" aria-checked="false" aria-label="Cambiar a facturación anual">
        <span class="toggle-thumb"></span>
      </button>
      <span class="billing-label" id="label-anual">
        Anual
        <span class="badge-ahorro">2 meses gratis</span>
      </span>
    </div>
  </div>

  <!-- Cards de planes -->
  <div class="planes-grid">

    <!-- PLAN ANCLA -->
    <div class="plan-card" id="plan-ancla">
      <div class="plan-head">
        <div class="plan-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v6M12 22v-4M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-4M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">Ancla</p>
          <p class="plan-tagline">Para comenzar con fuerza</p>
        </div>
      </div>

      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">1,699</span>
          <span class="price-period">/mes</span>
        </div>
        <p class="price-note" id="note-ancla">Facturado mensualmente</p>
      </div>

      <a href="#demo" class="plan-cta plan-cta--outline">Empezar gratis 14 días</a>

      <div class="plan-features">
        <p class="features-label">Incluye:</p>
        <ul class="features-list">
          <li class="feat feat--on"><span class="feat-icon">✓</span> 1 sede operativa</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Hasta 3 usuarios / doctores</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> 500 leads / mes</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> CRM con pipeline visual Kanban</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Agenda y gestión de citas</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> CRUD completo de pacientes / clientes</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Historial de interacciones por lead</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Notificaciones internas del equipo</li>

          <li class="feat feat--off"><span class="feat-icon">—</span> Email marketing</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> Finanzas y caja</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> Reportes avanzados</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> Multi-sede</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> WhatsApp Business API</li>
        </ul>
      </div>

      <p class="plan-support">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Soporte por email · Respuesta en 24 h
      </p>
    </div>

    <!-- PLAN COMANDO (destacado) -->
    <div class="plan-card plan-card--featured" id="plan-comando">
      <div class="plan-badge">Más popular</div>

      <div class="plan-head">
        <div class="plan-icon plan-icon--featured">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">Comando</p>
          <p class="plan-tagline">Para clínicas y agencias en crecimiento</p>
        </div>
      </div>

      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">2,199</span>
          <span class="price-period">/mes</span>
        </div>
        <p class="price-note" id="note-comando">Facturado mensualmente</p>
      </div>

      <a href="#demo" class="plan-cta plan-cta--primary">Solicitar demo</a>

      <div class="plan-features">
        <p class="features-label">Todo lo de Ancla, más:</p>
        <ul class="features-list">
          <li class="feat feat--on"><span class="feat-icon">✓</span> Hasta 3 sedes</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Hasta 10 usuarios / doctores</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> 2,000 leads / mes</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Email marketing automatizado</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Finanzas y caja en tiempo real</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Reportes y métricas avanzadas</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Multi-nicho configurable</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Automatización de tareas internas</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Control de inventario básico</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Roles y permisos por usuario</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> Sedes ilimitadas</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> WhatsApp Business API</li>
          <li class="feat feat--off"><span class="feat-icon">—</span> Onboarding dedicado</li>
  
        </ul>
      </div>

      <p class="plan-support plan-support--featured">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Soporte por chat · Respuesta en 4 h
      </p>
    </div>

    <!-- PLAN CORPORATIVO -->
    <div class="plan-card" id="plan-corporativo">
      <div class="plan-head">
        <div class="plan-icon plan-icon--corp">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
          </svg>
        </div>
        <div>
          <p class="plan-name">Corporativo</p>
          <p class="plan-tagline">Para redes multi-sede y equipos grandes</p>
        </div>
      </div>

      <div class="plan-price-wrap">
        <div class="plan-price">
          <span class="price-currency">$</span>
          <span class="price-amount">2,699</span>
          <span class="price-period">/mes</span>
        </div>
        <p class="price-note" id="note-corporativo">Facturado mensualmente</p>
      </div>

      <a href="#demo" class="plan-cta plan-cta--outline">Hablar con ventas</a>

      <div class="plan-features">
        <p class="features-label">Todo lo de Comando, más:</p>
        <ul class="features-list">
          <li class="feat feat--on"><span class="feat-icon">✓</span> Sedes ilimitadas</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Usuarios ilimitados</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Leads ilimitados</li>
          <li class="feat feat--on feat--highlight">
            <span class="feat-icon">✓</span>
            <span>WhatsApp Business API oficial (Meta) <span class="feat-new">NUEVO</span></span>
          </li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Recordatorios automáticos por WhatsApp</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Seguimiento instantáneo de leads vía WA</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> API pública para integraciones externas</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Onboarding y setup dedicado (4 h)</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Capacitación en vivo para tu equipo</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Gestor de cuenta asignado</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Uptime garantizado 99.9%</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Backups diarios automáticos</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Personalización de marca (white-label)</li>
          <li class="feat feat--on"><span class="feat-icon">✓</span> Acceso anticipado a nuevas funciones</li>
        </ul>
      </div>

      <p class="plan-support">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8a16 16 0 0 0 6 6l.27-.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16z"/></svg>
        Soporte prioritario 24/7 · Respuesta en 1 h
      </p>
    </div>

  </div><!-- /planes-grid -->



</section>

<link rel="stylesheet" href="/styles/PreciosIkari.css" />
<script src="/scripts/PreciosIkari.js" defer></script>
<script>
    import '../scripts/precios'
</script>